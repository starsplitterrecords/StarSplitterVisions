{
  "name": "star-splitter-visions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-assets": "tsx scripts/generate-assets.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:size": "node scripts/check-size-guardrails.js",
    "check:size:fail": "node scripts/check-size-guardrails.js --fail",
    "check": "npm run lint && npm run validate:content && npm run build",
    "validate:content": "node scripts/validate-content.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10",
    "tsx": "^4.20.0",
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.1.0",
    "prettier": "^3.5.3"
  }
}
